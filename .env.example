# ═══════════════════════════════════════════════════════════════════
#  GIC Plan-to-Perform: Environment Configuration
#  Copy this file to .env and fill in actual values
# ═══════════════════════════════════════════════════════════════════

# ── Financial Data APIs ───────────────────────────────────────────
FRED_API_KEY=your_fred_api_key_here
QUANDL_API_KEY=your_quandl_api_key
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# ── Crypto Exchange (CCXT) ───────────────────────────────────────
# Optional: only needed if you want authenticated private endpoints
BINANCE_API_KEY=
BINANCE_SECRET=

# ── Database / Data Lake ─────────────────────────────────────────
DATA_LAKE_CONNECTION_STRING=sqlite:///data/local.db
SAP_ERP_HOST=placeholder_host
SAP_ERP_PORT=443

# ── Application Settings ─────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501

# ── Model Settings ───────────────────────────────────────────────
MODEL_REGISTRY_PATH=models/saved
FORECAST_HORIZON_MONTHS=12
MONTE_CARLO_SIMULATIONS=10000
